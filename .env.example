# ============================================
# 云游 CloudRoam · 环境变量
# ============================================
# 使用：复制此文件为 .env.local 并填入真实值
# 国内直连版：不需要科学上网，全部服务国内可访问

# ---------- Supabase ----------
# 数据库 + 实时协作，国内可直连（Tokyo/Singapore 节点）
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...

# ---------- 智谱 AI GLM-4-Flash（完全免费）----------
# 在 https://open.bigmodel.cn/ 用手机号注册获取 API Key
# GLM-4-Flash 每月 2000 万 tokens 免费额度，MVP 用不完
ZHIPU_API_KEY=xxxxxxxxxxxxxx.xxxxxxxxxx

# 可选：指定模型，默认 glm-4-flash（免费）
# 备选：glm-4-flashx（更快，也在免费额度内）
# ZHIPU_MODEL=glm-4-flash

# ---------- 应用 ----------
NEXT_PUBLIC_APP_URL=http://localhost:3000
